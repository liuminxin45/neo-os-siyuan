{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leoiu.local/siyuan-addon/plugin-settings.schema.json",
  "title": "PluginSettings",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "llmProfiles", "mcpServers"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "activeProfileId": { "type": "string" },
    "llmProfiles": {
      "type": "array",
      "items": { "$ref": "./llm-profile.schema.json" }
    },
    "mcpServers": {
      "type": "array",
      "items": { "$ref": "./mcp-server.schema.json" }
    },
    "mcpToolCache": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "$ref": "./mcp-tool.schema.json" }
      }
    },
    "agentMode": { "enum": ["react", "reflection", "plan-and-execute"] },
    "maxMemoryTurns": { "enum": [5, 10, 20, 30] }
  }
}
