{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leoiu.local/siyuan-addon/llm-profile.schema.json",
  "title": "LLMProfile",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "provider", "apiKey", "model", "createdAt", "updatedAt"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "provider": { "enum": ["openai-compatible", "deepseek"] },
    "baseUrl": { "type": "string" },
    "apiKey": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "provider": { "const": "openai-compatible" }
        },
        "required": ["provider"]
      },
      "then": {
        "required": ["baseUrl"]
      }
    }
  ]
}
